# API 密钥配置示例
#
# 当前默认：
#   - 步骤8 图片生成：ApiMart / gemini-3.1-flash-image-preview
#   - 步骤9 视频生成：VolcEngine / doubao-seedance-2-0-fast-260128
#
# 费用参考（仅供参考，以官网为准）：
#   - ApiMart 图片生成：以 ApiMart 控制台计费为准
#   - Seedance 视频生成：约 0.5-2 元/秒（720p）
#   - edge_tts（TTS）：完全免费
#
# 安全提示：
#   此文件已加入 .gitignore，请勿将实际密钥提交到 Git 仓库

apimart:
  api_key: "your-apimart-api-key-here"
  # api_base 无需修改，默认值在 api_config.yaml 中已配置
  # api_base: "https://api.apimart.ai/v1"

volcengine:
  api_key: "your-volcengine-api-key-here"
  # api_base 无需修改，默认值在 api_config.yaml 中已配置
  # api_base: "https://ark.cn-beijing.volces.com/api/v3"
